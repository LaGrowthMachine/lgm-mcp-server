{
    "name": "lgm-mcp-server",
    "version": "1.0.0",
    "description": "MCP Server for LaGrowthMachine - exposes LGM capabilities to external AI agents",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "start:stdio": "LGM_MCP_TRANSPORT=stdio node dist/index.js",
        "dev": "ts-node src/index.ts",
        "test": "jest --runInBand"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.0",
        "typescript": "^5.3.3",
        "ts-node": "^10.9.2",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "@types/jest": "^29.5.11"
    }
}
