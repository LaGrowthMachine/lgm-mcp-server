# Local dev env vars. Copy to .env (gitignored) and fill values.
# Loaded automatically by bin/lgm-mongosh via dotenv (try/catch — optional).

# Readonly slave Mongo connection string (full URI with credentials + db name).
# Fetch from Heroku: `heroku config:get LGM_MONGO_URI -a lgm-mcp-server-alexis`
LGM_MONGO_URI=

# Anthropic API key (used by agentLoop.ts for the Heroku-side agent).
# Not needed for bin/lgm-mongosh — only if running the server locally.
REPLY_MANAGER_API_KEY=
